{
  "name": "aidana-agent",
  "version": "0.0.1",
  "description": "AI voice agent for macOS, with on-device ASR and TTS",
  "scripts": {
    "prebuild": "rm -rf ./dist && rm -rf ./node_modules/.bun",
    "build": "vite build",
    "build:embedded-mcp": "bun ./scripts/build-embedded-mcp.mjs",
    "prepare:talkinghead-assets": "sh ../scripts/prepare-talkinghead-assets.sh",
    "prepare:embedded-node": "sh ../scripts/prepare-embedded-node.sh",
    "test:browser-automation": "tsx example-browser-automation.ts",
    "test:mcp": "tsx example-mcp-inspect.ts",
    "test:file-search": "tsx example-mcp-file-search.ts",
    "test:doctor-search": "tsx example-mcp-doctor-search.ts",
    "mcp": "tsx mcp-server.ts"
  },
  "author": "Aron Homberg <info@aron-homberg.de>",
  "dependencies": {
    "@crxjs/vite-plugin": "^2.3.0",
    "@incremark/core": "^1.0.2",
    "@met4citizen/talkinghead": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.1.18",
    "defuss": "^3.4.1",
    "defuss-db": "^1.1.4",
    "defuss-dson": "^1.1.1",
    "defuss-markdown": "^1.0.1",
    "defuss-rpc": "^1.3.1",
    "defuss-shadcn": "^0.6.1",
    "defuss-vad": "^1.1.0",
    "defuss-vite": "^1.1.3",
    "dexie": "^4.3.0",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1"
  },
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/chrome": "^0.1.37",
    "@types/dom-webcodecs": "^0.1.18",
    "express": "^5.2.1",
    "rollup-plugin-sourcemaps": "^0.6.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
